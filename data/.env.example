# ── 复制本文件为 .env 后按需修改 ──  cp .env.example .env

# 服务端口
PORT=3000

# JWT 签名密钥 —— 生产环境务必改成一段随机长字符串!
# 生成示例:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=请改成一段随机的长字符串

# 登录令牌有效期(支持 7d / 24h / 30m 等写法)
JWT_EXPIRES=7d

# ───────── 数据库 ─────────
# 方案一(生产/免费托管,推荐):用 Turso 云端数据库,数据持久。
#   1) 安装 CLI 并登录:  curl -sSfL https://get.tur.so/install.sh | bash  然后  turso auth signup
#   2) 建库:            turso db create gesp
#   3) 取连接串:        turso db show gesp --url        （形如 libsql://gesp-xxx.turso.io）
#   4) 建令牌:          turso db tokens create gesp
# 然后填入下面两项(取消注释):
# TURSO_DATABASE_URL=libsql://gesp-你的子域.turso.io
# TURSO_AUTH_TOKEN=粘贴上一步生成的 token

# 方案二(本地开发):不设上面两个 TURSO_ 变量时,自动使用本地 SQLite 文件(下方路径)。
DB_PATH=./data/gesp.db

# 题库种子(库为空时导入的 325 题)
SEED_PATH=./data/site_data.json
